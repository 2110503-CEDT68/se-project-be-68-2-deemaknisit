{
  "info": {
    "name": "Car Wishlist List Testing",
    "description": "Postman collection covering guest and authenticated wishlist status on GET /api/cars.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('RUN_SUFFIX')) {",
          "  const suffix = Date.now().toString();",
          "  pm.collectionVariables.set('RUN_SUFFIX', suffix);",
          "  pm.collectionVariables.set('ADMIN_EMAIL', `car-wishlist.admin.${suffix}@example.com`);",
          "  pm.collectionVariables.set('USER_EMAIL', `car-wishlist.user.${suffix}@example.com`);",
          "  pm.collectionVariables.set('USER2_EMAIL', `car-wishlist.user2.${suffix}@example.com`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Register Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Car Wishlist Admin\",\n  \"email\": \"{{ADMIN_EMAIL}}\",\n  \"telephone\": \"0811111111\",\n  \"password\": \"secret123\",\n  \"role\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{URL}}/api/auth/register",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{ADMIN_EMAIL}}\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{URL}}/api/auth/login",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('ADMIN_TOKEN', pm.response.json().token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Register Wishlist User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Car Wishlist User\",\n  \"email\": \"{{USER_EMAIL}}\",\n  \"telephone\": \"0822222222\",\n  \"password\": \"secret123\",\n  \"role\": \"user\"\n}"
        },
        "url": {
          "raw": "{{URL}}/api/auth/register",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login Wishlist User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{USER_EMAIL}}\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{URL}}/api/auth/login",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('USER_TOKEN', pm.response.json().token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Register User Without Wishlist",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Car Wishlist User 2\",\n  \"email\": \"{{USER2_EMAIL}}\",\n  \"telephone\": \"0833333333\",\n  \"password\": \"secret123\",\n  \"role\": \"user\"\n}"
        },
        "url": {
          "raw": "{{URL}}/api/auth/register",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login User Without Wishlist",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{USER2_EMAIL}}\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{URL}}/api/auth/login",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('USER2_TOKEN', pm.response.json().token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Provider",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{ADMIN_TOKEN}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Provider For Car Wishlist {{RUN_SUFFIX}}\",\n  \"address\": \"Address\",\n  \"district\": \"District\",\n  \"province\": \"Bangkok\",\n  \"postalcode\": \"10110\",\n  \"tel\": \"021111111\",\n  \"region\": \"Central\"\n}"
        },
        "url": {
          "raw": "{{URL}}/api/providers",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "providers"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('PROVIDER_ID', pm.response.json().data._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Car A",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{ADMIN_TOKEN}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"licensePlate\": \"CAR-A-{{RUN_SUFFIX}}\",\n  \"brand\": \"Brand A\",\n  \"model\": \"Model A\",\n  \"year\": 2024,\n  \"color\": \"Black\",\n  \"transmission\": \"Automatic\",\n  \"fuelType\": \"Gasoline\",\n  \"rentPrice\": 1000,\n  \"provider\": \"{{PROVIDER_ID}}\"\n}"
        },
        "url": {
          "raw": "{{URL}}/api/cars",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "cars"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('CAR_A_ID', pm.response.json().data._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Car B",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{ADMIN_TOKEN}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"licensePlate\": \"CAR-B-{{RUN_SUFFIX}}\",\n  \"brand\": \"Brand B\",\n  \"model\": \"Model B\",\n  \"year\": 2024,\n  \"color\": \"White\",\n  \"transmission\": \"Manual\",\n  \"fuelType\": \"Diesel\",\n  \"rentPrice\": 1200,\n  \"provider\": \"{{PROVIDER_ID}}\"\n}"
        },
        "url": {
          "raw": "{{URL}}/api/cars",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "cars"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('CAR_B_ID', pm.response.json().data._id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Cars As Guest",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{URL}}/api/cars?licensePlate[in]=CAR-A-{{RUN_SUFFIX}},CAR-B-{{RUN_SUFFIX}}&sort=licensePlate",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "cars"
          ],
          "query": [
            {
              "key": "licensePlate[in]",
              "value": "CAR-A-{{RUN_SUFFIX}},CAR-B-{{RUN_SUFFIX}}"
            },
            {
              "key": "sort",
              "value": "licensePlate"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Guest car list succeeds', () => pm.response.to.have.status(200));",
              "const cars = pm.response.json().data;",
              "pm.test('Guest cars expose isWishlisted=null', () => {",
              "  pm.expect(cars.length).to.be.greaterThan(0);",
              "  cars.forEach((car) => {",
              "    pm.expect(car).to.have.property('isWishlisted');",
              "    pm.expect(car.isWishlisted).to.be.null;",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Add Car A To Wishlist",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{USER_TOKEN}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"carId\": \"{{CAR_A_ID}}\"\n}"
        },
        "url": {
          "raw": "{{URL}}/api/wishlist",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "wishlist"
          ]
        }
      }
    },
    {
      "name": "Get Cars As Authenticated User With Wishlist",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{USER_TOKEN}}"
          }
        ],
        "url": {
          "raw": "{{URL}}/api/cars?licensePlate[in]=CAR-A-{{RUN_SUFFIX}},CAR-B-{{RUN_SUFFIX}}&sort=licensePlate",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "cars"
          ],
          "query": [
            {
              "key": "licensePlate[in]",
              "value": "CAR-A-{{RUN_SUFFIX}},CAR-B-{{RUN_SUFFIX}}"
            },
            {
              "key": "sort",
              "value": "licensePlate"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Authenticated car list succeeds', () => pm.response.to.have.status(200));",
              "const cars = pm.response.json().data;",
              "const byId = Object.fromEntries(cars.map((car) => [car._id, car]));",
              "pm.test('isWishlisted flags are correct', () => {",
              "  pm.expect(byId['{{CAR_A_ID}}'].isWishlisted).to.not.be.null;",
              "  pm.expect(byId['{{CAR_B_ID}}'].isWishlisted).to.be.null;",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "URL",
      "value": "http://localhost:5000"
    }
  ]
}
